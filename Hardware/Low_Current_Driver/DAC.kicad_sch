	(text "RS: Reset Pin,\n	resests to either half scale or zero scale\n	depending on the logic of MSB pin\n\nMSB: Sets half of MSB of input code when reset. \n\nLDAC: Load DAC\n	DAC is double buffered, you first clock in\n	the new values and stage them. At this point \n	nothing is writen to the output. Then when LDAC\n	pulsed, everything that was changed to written to \n	the output allowing channels to be synced.\n\n\n"
		(exclude_from_sim no)
		(at 83.058 80.772 0)
		(effects
			(font
				(size 0.635 0.635)
			)
		)
		(uuid "b47d0bc7-8d2a-4bf5-ab56-62387a172dee")
	)
