	(text "Resistors have to match expected\nimpedance of DAC output\n(balance between noise and power)"
		(exclude_from_sim no)
		(at 167.64 26.67 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "a8e6688b-3fe1-45bd-9a6d-e5ee6aa7e5f6")
	)
	(text "RS: Reset Pin,\n	resests to either half scale or zero scale\n	depending on the logic of MSB pin\n\nMSB: Sets half of MSB of input code when reset. \n\nLDAC: Load DAC\n	DAC is double buffered, you first clock in\n	the new values and stage them. At this point \n	nothing is writen to the output. Then when LDAC\n	pulsed, everything that was changed to written to \n	the output allowing channels to be synced.\n\n\n"
		(exclude_from_sim no)
		(at 83.058 80.772 0)
		(effects
			(font
				(size 0.635 0.635)
			)
		)
		(uuid "b47d0bc7-8d2a-4bf5-ab56-62387a172dee")
	)
	(text "Four quadrant stage (enables bidirectional current flow)\ncompensated to 160 Hz for lower noise\n\n"
		(exclude_from_sim no)
		(at 207.01 20.32 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "ed1f6084-216d-4440-bc91-a7e046387430")
	)
